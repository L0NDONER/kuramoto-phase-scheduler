[Unit]
Description=Pi2 trineuron Triangle B (cpufreq controller)
After=network-online.target reader.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/home/pi/pi2_dvfs_reader
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
